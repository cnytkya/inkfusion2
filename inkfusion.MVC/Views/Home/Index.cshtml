@model HomePageViewModel

@{
    ViewData["Title"] = "InkFusion - Piercing Tattoo Studio";
}

@if (Model?.HeroSection != null)
{
    <section id="home" class="hero-section">
        @if (!string.IsNullOrEmpty(Model.HeroSection.ImageUrl))
        {
            <div class="video-background">
                <img src="@Model.HeroSection.ImageUrl" alt="Hero" class="hero-image" />
            </div>
        }
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8 mx-auto text-center">
                        <h1 class="hero-title">@Html.Raw(Model.HeroSection.Title)</h1>
                        @if (!string.IsNullOrEmpty(Model.HeroSection.Subtitle))
                        {
                            <p class="hero-subtitle">@Model.HeroSection.Subtitle</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.HeroSection.Description))
                        {
                            <p class="hero-description">@Model.HeroSection.Description</p>
                        }
                        <div class="hero-buttons mt-4">
                            @if (!string.IsNullOrEmpty(Model.HeroSection.ButtonText) && !string.IsNullOrEmpty(Model.HeroSection.ButtonLink))
                            {
                                <a href="@Model.HeroSection.ButtonLink" class="btn btn-primary me-3">@Model.HeroSection.ButtonText</a>
                            }
                            <a href="#gallery" class="btn btn-outline">İşlerimize Bak</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-scroll">
            <a href="#about"><i class="fas fa-chevron-down"></i></a>
        </div>
    </section>
}

<section id="about" class="section-padding">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="about-image">
                    <video autoplay muted loop playsinline id="about-video">
                        <source src="videos/v2.mp4" type="video/mp4">
                        Tarayıcınız video etiketini desteklemiyor.
                    </video>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="about-title">Hakkımızda</h2>
                    <div class="section-divider"></div>
                </div>
                <p class="about-text" data-lang-key="about-text">
                    10 yılı aşkın tecrübemizle, İstanbul'un en gözde dövme stüdyosu olarak
                    hizmet vermekteyiz. Uzman ekibimiz ve steril çalışma ortamımızla
                    müşterilerimize en kaliteli hizmeti sunmaktan gurur duyuyoruz.
                </p>
                <div class="about-features">
                    <div class="feature-item">
                        <i class="fas fa-star feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature1-title">Özel Tasarımlar</h4>
                            <p data-lang-key="feature1-text">Tamamen size özel ve benzersiz çizimler.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-award feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature2-title">Kaliteli İşçilik</h4>
                            <p data-lang-key="feature2-text">En kaliteli mürekkep ve ekipmanlarla çalışıyoruz.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-users feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature3-title">Uzman Ekip</h4>
                            <p data-lang-key="feature3-text">Alanında uzman deneyimli dövme sanatçıları.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model?.Services != null && Model.Services.Count > 0)
{
    <section id="services" class="section-padding bg-dark-custom">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <div class="section-heading">
                        <h2 class="section-title">Hizmetlerimiz</h2>
                        <div class="section-divider"></div>
                        <p class="section-subtitle">Size özel çözümler sunuyoruz</p>
                    </div>
                </div>
            </div>
            <div class="row mt-5">
                @foreach (var service in Model.Services.Where(s => s.IsActive).OrderBy(s => s.Order))
                {
                    <div class="col-md-4 mb-4">
                        <div class="service-card">
                            @if (!string.IsNullOrEmpty(service.IconClass))
                            {
                                <div class="service-icon">
                                    <i class="@service.IconClass"></i>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(service.ImageUrl))
                            {
                                <div class="service-image">
                                    <img src="@service.ImageUrl" alt="@service.Name" />
                                </div>
                            }
                            <h3>@service.Name</h3>
                            @if (!string.IsNullOrEmpty(service.Description))
                            {
                                <p>@service.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@if (Model?.Galleries != null && Model.Galleries.Count > 0)
{
    <section id="gallery" class="section-padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <div class="section-heading">
                        <h2 class="section-title">Galeri</h2>
                        <div class="section-divider"></div>
                        <p class="section-subtitle">Yaptığımız bazı çalışmalar</p>
                    </div>
                </div>
            </div>
            <div class="row mt-5">
                @{
                    var activeGalleries = Model.Galleries.Where(g => g.IsActive).OrderBy(g => g.Order).Take(12).ToList();
                }
                @foreach (var gallery in activeGalleries)
                {
                    <div class="col-md-4 mb-4">
                        <div class="gallery-item">
                            <div class="gallery-image" style="background-image: url('@gallery.ImageUrl');">
                                <div class="gallery-overlay">
                                    @if (!string.IsNullOrEmpty(gallery.Title))
                                    {
                                        <h4>@gallery.Title</h4>
                                    }
                                    @if (!string.IsNullOrEmpty(gallery.Category))
                                    {
                                        <p>@gallery.Category</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeGalleries.Count > 0)
                {
                    <div class="col-12 text-center mt-4">
                        <a asp-controller="Inkfusion" asp-action="gallery" class="btn btn-primary animated-link">Daha Fazlası İçin Tıklayın</a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<section id="artists" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="artists-title">Sanatçılarımız</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="artists-subtitle">Uzman ekibimizle tanışın</p>
                </div>
            </div>
        </div>
        @await Html.PartialAsync("_ArtistsSection")
    </div>
</section>

@if (Model?.Testimonials != null && Model.Testimonials.Count > 0)
{
    <section id="testimonials" class="section-padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <div class="section-heading">
                        <h2 class="section-title">Müşteri Yorumları</h2>
                        <div class="section-divider"></div>
                        <p class="section-subtitle">Müşterilerimizin deneyimleri</p>
                    </div>
                </div>
            </div>
            <div class="row mt-5">
                @foreach (var testimonial in Model.Testimonials.Where(t => t.IsActive).Take(6))
                {
                    <div class="col-md-4 mb-4">
                        <div class="testimonial-card">
                            <div class="testimonial-text">
                                <i class="fas fa-quote-left quote-icon"></i>
                                <p>@testimonial.Message</p>
                            </div>
                            @if (!string.IsNullOrEmpty(testimonial.Rating.ToString()))
                            {
                                <div class="testimonial-rating">
                                    @for (int i = 1; i <= testimonial.Rating; i++)
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    @for (int i = testimonial.Rating; i < 5; i++)
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                </div>
                            }
                            <div class="testimonial-author">
                                @if (!string.IsNullOrEmpty(testimonial.ImageUrl))
                                {
                                    <div class="author-image" style="background-image: url('@testimonial.ImageUrl');"></div>
                                }
                                else
                                {
                                    <div class="author-image" style="background-image: url('https://placehold.co/60x60/1a1a1a/FFFFFF/png?text=Avatar');"></div>
                                }
                                <div class="author-info">
                                    <h5>@testimonial.Name</h5>
                                    @if (!string.IsNullOrEmpty(testimonial.Title))
                                    {
                                        <p>@testimonial.Title</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<section id="contact" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title">İletişim</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle">Randevu ve bilgi almak için bize ulaşın</p>
                </div>
            </div>
        </div>

        @if (Model?.ContactInfo != null && Model.ContactInfo.Count > 0)
        {
            <div class="row mt-4 mb-5">
                @foreach (var contact in Model.ContactInfo.Where(c => c.IsActive))
                {
                    <div class="col-md-4 mb-3">
                        <div class="contact-info-card text-center">
                            @if (!string.IsNullOrEmpty(contact.IconClass))
                            {
                                <div class="contact-icon">
                                    <i class="@contact.IconClass"></i>
                                </div>
                            }
                            <h5>@contact.Key</h5>
                            <p class="text-light">@contact.Value</p>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <form id="contactForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" class="form-control" placeholder="Adınız Soyadınız" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <input type="email" class="form-control" placeholder="E-posta Adresiniz" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Konu">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" rows="5" placeholder="Mesajınız" required></textarea>
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary">Gönder</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-12">
                <div class="google-maps-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3010.598284725595!2d29.02294151528652!3d40.99268757930351!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab84c47d3c01f%3A0xc3b8a1c9b6f1e1d3!2sCafera%C4%9Fa%2C%20Nail%20Bey%20Sk.%20No%3A%203%2C%2034710%20Kad%C4%B1k%C3%B6y%2F%C4%B0stanbul!5e0!3m2!1str!2str!4v1672531200000!5m2!1str!2str"
                            width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="inkfusiontattoopiercing"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Navbar ve smooth scroll
            window.addEventListener('scroll', function() {
                const navbar = document.querySelector('.custom-navbar');
                if (window.scrollY > 50) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            });

            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('href');
                    if (targetId === '#') return;
                    const targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        window.scrollTo({
                            top: targetElement.offsetTop - 70,
                            behavior: 'smooth'
                        });
                    }
                });
            });
        });
    </script>
}