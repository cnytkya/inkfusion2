@{
    ViewData["Title"] = "InkFusion - Piercing Tattoo Studio";
}

<section id="home" class="hero-section">
    <div class="video-background">
        <video autoplay muted loop playsinline id="hero-video">
            <source src="videos/v1.MP4" type="video/mp4">
        </video>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h1 class="hero-title" data-lang-key="hero-title">Sanatını <span class="text-accent">Vücudunda</span> Taşı</h1>
                    <p class="hero-subtitle" data-lang-key="hero-subtitle">Profesyonel dövme sanatçıları ile hayalindeki dövmeyi gerçeğe dönüştürüyoruz.</p>
                    <div class="hero-buttons mt-4">
                        <a href="#contact" class="btn btn-primary me-3" data-lang-key="book-now">Randevu Al</a>
                        <a href="#gallery" class="btn btn-outline" data-lang-key="view-work">İşlerimize Bak</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-scroll">
        <a href="#about"><i class="fas fa-chevron-down"></i></a>
    </div>
</section>

<section id="about" class="section-padding">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="about-image">
                    <video autoplay muted loop playsinline id="about-video">
                        <source src="videos/v2.mp4" type="video/mp4">
                        Tarayıcınız video etiketini desteklemiyor.
                    </video>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="about-title">Hakkımızda</h2>
                    <div class="section-divider"></div>
                </div>
                <p class="about-text" data-lang-key="about-text">
                    10 yılı aşkın tecrübemizle, İstanbul'un en gözde dövme stüdyosu olarak
                    hizmet vermekteyiz. Uzman ekibimiz ve steril çalışma ortamımızla
                    müşterilerimize en kaliteli hizmeti sunmaktan gurur duyuyoruz.
                </p>
                <div class="about-features">
                    <div class="feature-item">
                        <i class="fas fa-star feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature1-title">Özel Tasarımlar</h4>
                            <p data-lang-key="feature1-text">Tamamen size özel ve benzersiz çizimler.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-award feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature2-title">Kaliteli İşçilik</h4>
                            <p data-lang-key="feature2-text">En kaliteli mürekkep ve ekipmanlarla çalışıyoruz.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-users feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature3-title">Uzman Ekip</h4>
                            <p data-lang-key="feature3-text">Alanında uzman deneyimli dövme sanatçıları.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="services" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="services-title">Hizmetlerimiz</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="services-subtitle">Size özel çözümler sunuyoruz</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-drafting-compass"></i>
                    </div>
                    <h3 data-lang-key="service1-title">Özel Tasarım</h3>
                    <p data-lang-key="service1-text">Hayalinizdeki dövmeyi birlikte tasarlayalım. Tamamen size özel ve özgün çizimler.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-paint-brush"></i>
                    </div>
                    <h3 data-lang-key="service2-title">Renkli Dövmeler</h3>
                    <p data-lang-key="service2-text">Canlı ve kalıcı renklerle hayalinizdeki dövmeyi sanat eserine dönüştürüyoruz.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-magic"></i>
                    </div>
                    <h3 data-lang-key="service3-title">Cover Up (Dövme Kapatma)</h3>
                    <p data-lang-key="service3-text">İstemediğiniz dövmeleri, profesyonel dokunuşlarla yepyeni bir sanat eserine dönüştürüyoruz.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="gallery" class="section-padding">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="gallery-title">Galeri</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="gallery-subtitle">Yaptığımız bazı çalışmalar</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            @* Sadece ilk 12 resmi gösteren döngü *@
            @for (int i = 1; i <= 12; i++)
            {
                <div class="col-md-4 mb-4">
                    <div class="gallery-item">
                        <div class="gallery-image" style="background-image: url('img/gallery/realistic/@(i).jpg');">
                            <div class="gallery-overlay">
                                @*<h4 data-lang-key="tattoo1-title">Dövme @i</h4>*@
                                <p data-lang-key="tattoo1-style">Realistik</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="col-12 text-center mt-4">
                <a asp-controller="Inkfusion" asp-action="gallery" class="btn btn-primary animated-link" data-lang-key="view-all-gallery">Daha Fazlası İçin Tıklayın</a>
            </div>
        </div>
    </div>
</section>

<section id="artists" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="artists-title">Sanatçılarımız</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="artists-subtitle">Uzman ekibimizle tanışın</p>
                </div>
            </div>
        </div>
        @await Html.PartialAsync("_ArtistsSection")
    </div>
</section>

<section id="testimonials" class="section-padding">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="testimonials-title">Müşteri Yorumları</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="testimonials-subtitle">Müşterilerimizin deneyimleri</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="testimonial-card">
                    <div class="testimonial-text">
                        <i class="fas fa-quote-left quote-icon"></i>
                        <p data-lang-key="testimonial1-text">Harika bir deneyimdi. Temizlik ve hijyen konusunda çok titizler. Dövmem tam istediğim gibi oldu.</p>
                    </div>
                    <div class="testimonial-author">
                        <div class="author-image" style="background-image: url('https://placehold.co/60x60/1a1a1a/FFFFFF/png?text=DK');"></div>
                        <div class="author-info">
                            <h5 data-lang-key="testimonial1-author">Deniz K.</h5>
                            <p data-lang-key="testimonial1-tattoo-style">Kol Dövmesi</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="testimonial-card">
                    <div class="testimonial-text">
                        <i class="fas fa-quote-left quote-icon"></i>
                        <p data-lang-key="testimonial2-text">Sanatçılar gerçekten çok yetenekli. Özel tasarım sürecinde tüm isteklerimi dikkate aldılar.</p>
                    </div>
                    <div class="testimonial-author">
                        <div class="author-image" style="background-image: url('https://placehold.co/60x60/1a1a1a/FFFFFF/png?text=AS');"></div>
                        <div class="author-info">
                            <h5 data-lang-key="testimonial2-author">Ahmet S.</h5>
                            <p data-lang-key="testimonial2-tattoo-style">Özel Tasarım</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="testimonial-card">
                    <div class="testimonial-text">
                        <i class="fas fa-quote-left quote-icon"></i>
                        <p data-lang-key="testimonial3-text">Dövme silme işlemi yaptırdım. Sonuç mükemmel, neredeyse hiç iz kalmadı. Teşekkürler!</p>
                    </div>
                    <div class="testimonial-author">
                        <div class="author-image" style="background-image: url('https://placehold.co/60x60/1a1a1a/FFFFFF/png?text=EY');"></div>
                        <div class="author-info">
                            <h5 data-lang-key="testimonial3-author">Elif Y.</h5>
                            <p data-lang-key="testimonial3-tattoo-style">Dövme Kapatma</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="contact-title">İletişim</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="contact-subtitle">Randevu ve bilgi almak için bize ulaşın</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <form id="contactForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" class="form-control" placeholder="Adınız Soyadınız" required data-lang-key="contact-name-placeholder">
                        </div>
                        <div class="col-md-6 mb-3">
                            <input type="email" class="form-control" placeholder="E-posta Adresiniz" required data-lang-key="contact-email-placeholder">
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Konu" data-lang-key="contact-subject-placeholder">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" rows="5" placeholder="Mesajınız" required data-lang-key="contact-message-placeholder"></textarea>
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary" data-lang-key="contact-submit-btn">Gönder</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-12">
                <div class="google-maps-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3010.598284725595!2d29.02294151528652!3d40.99268757930351!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab84c47d3c01f%3A0xc3b8a1c9b6f1e1d3!2sCafera%C4%9Fa%2C%20Nail%20Bey%20Sk.%20No%3A%203%2C%2034710%20Kad%C4%B1k%C3%B6y%2F%C4%B0stanbul!5e0!3m2!1str!2str!4v1672531200000!5m2!1str!2str"
                            width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="inkfusiontattoopiercing"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Navbar ve smooth scroll
            window.addEventListener('scroll', function() {
                const navbar = document.querySelector('.custom-navbar');
                if (window.scrollY > 50) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            });

            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('href');
                    if (targetId === '#') return;
                    const targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        window.scrollTo({
                            top: targetElement.offsetTop - 70,
                            behavior: 'smooth'
                        });
                    }
                });
            });
        });
    </script>
}