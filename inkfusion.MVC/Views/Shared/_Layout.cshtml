<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] INKFUSION TATTO & PIERCING STUDIO</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/inkfusion.MVC.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
</head>
<body data-theme="dark">
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top custom-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/img/logo/logo.png" alt="InkFusion Logo" class="navbar-logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/#home" data-lang-key="home">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#about" data-lang-key="about">Hakkımızda</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#services" data-lang-key="services">Hizmetler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#gallery" data-lang-key="gallery">Galeri</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#artists" data-lang-key="artists">Sanatçılar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#testimonials" data-lang-key="testimonials">Yorumlar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#contact" data-lang-key="contact">İletişim</a>
                    </li>
                    @{
                        var userName = Context.Session.GetString("UserName");
                    }
                    @if (string.IsNullOrEmpty(userName))
                    {
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary text-white ms-2" href="/Login" style="border-radius: 5px;">
                                <i class="fas fa-sign-in-alt me-1"></i>Giriş Yap
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user me-1"></i>@userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item" href="/Admin/Dashboard"><i class="fas fa-tachometer-alt me-2"></i>Admin Panel</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/Logout"><i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <div class="fixed-social-icons">
        <a href="https://wa.me/905312880161" target="_blank" class="social-icon whatsapp" aria-label="Whatsapp" data-hover-text-tr="Mesaj atmak için tıklayın" data-hover-text-en="Click to message">
            <i class="fab fa-whatsapp"></i>
        </a>
        <a href="https://www.instagram.com/inkftattoopiercing" target="_blank" class="social-icon instagram" aria-label="Instagram" data-hover-text-tr="Bizi takip edin" data-hover-text-en="Follow us">
            <i class="fab fa-instagram"></i>
        </a>
    </div>

    <footer class="footer-section text-center text-lg-start">
        <div class="container pt-5">
            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase footer-heading">InkFusion</h5>
                    <p class="footer-text" data-lang-key="footer-about-text">
                        Sanatını seven, kaliteyi önemseyen bir dövme stüdyosu.
                        Sizlere en iyi hizmeti sunmak için buradayız.
                    </p>
                </div>

                <div class="col-lg-4 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase footer-heading" data-lang-key="contact-info-title">İletişim</h5>
                    <ul class="list-unstyled">
                        <li class="footer-text">
                            <i class="fas fa-map-marker-alt me-2"></i> <span data-lang-key="address">Taksim, İstanbul</span>
                        </li>
                        <li class="footer-text">
                            <i class="fas fa-phone me-2"></i> <span data-lang-key="phone">
                                +90 531 288 01 61
                            </span>
                        </li>
                        <li class="footer-text">
                            <i class="fas fa-envelope me-2"></i> <span data-lang-key="email">ciniogluserap@gmail.com</span>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6 mb-4 mb-md-0">
                    <h5 class="text-uppercase footer-heading" data-lang-key="social-media-title">Sosyal Medya</h5>
                    <div class="social-links">
                        <a href="https://www.instagram.com/inkftattoopiercing/" class="social-link"><i class="fab fa-instagram"></i></a>
                        <a href="https://www.linkedin.com/in/cuneytkayadev" class="social-link"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center p-3 copyright">
            © 2025 - Bu site **Cüneyt Kaya** tarafından yapıldı. İletişim için <a href="http://www.cuneytkayadev.com" target="_blank" class="footer-link">www.cuneytkayadev.com</a> sitesini ziyaret edin. - <a asp-area="" asp-controller="Home" asp-action="Privacy" data-lang-key="privacy">Gizlilik</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/global.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var typed = new Typed("#typed-slogan", {
                strings: [
                    "Sanatın Bedenle Buluştuğu Yer",
                    "Tattoo Piercing Studio Kadıköy"
                ],
                typeSpeed: 60,
                backSpeed: 40,
                backDelay: 2000,
                loop: true
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>