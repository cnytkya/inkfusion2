@{
    var artists = (List<inkfusion.MVC.Models.Artist>)ViewBag.Artists ?? new List<inkfusion.MVC.Models.Artist>();
}

@if (artists != null && artists.Count > 0)
{
    <div class="row mt-5">
        @foreach (var artist in artists)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="artist-card animated-card">
                    <div class="artist-image-wrapper">
                        <div class="artist-image" style="background-image: url('@artist.ImageUrl');">
                            <div class="artist-overlay">
                                <i class="fas fa-star"></i>
                            </div>
                        </div>
                    </div>
                    <div class="artist-info">
                        <h3>@artist.Name</h3>
                        <p class="artist-specialty">
                            <i class="fas fa-brush"></i> @artist.Specialty
                        </p>
                        <p class="artist-bio">@artist.Bio</p>
                        <div class="artist-social">
                            <a href="https://www.instagram.com/inkfusion.kadikoy" target="_blank" title="Instagram"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="row mt-5">
        <div class="col-12 text-center">
            <div class="empty-state">
                <i class="fas fa-palette"></i>
                <p>Sanatçılar yakında eklenecek</p>
            </div>
        </div>
    </div>
}
