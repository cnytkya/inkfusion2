@model IEnumerable<inkfusion.MVC.Models.User>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="mb-0">
            <i class="fas fa-user-shield me-2"></i>Kullanıcı Yönetimi
        </h2>
    </div>
    <div class="col-md-4 text-end">
        <a href="/Admin/Users/Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Yeni Kullanıcı Ekle
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Ad</th>
                <th>E-posta</th>
                <th>Durum</th>
                <th>Oluşturulma Tarihi</th>
                <th class="text-center" style="width: 200px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <strong>@user.Name</strong>
                        </td>
                        <td>
                            <small>@user.Email</small>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check me-1"></i>Aktif
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="fas fa-times me-1"></i>İnaktif
                                </span>
                            }
                        </td>
                        <td>
                            <small>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </td>
                        <td class="text-center">
                            <a href="/Admin/Users/Edit/@user.Id" class="btn btn-sm btn-warning" title="Düzenle">
                                <i class="fas fa-edit"></i>
                            </a>

                            @if (user.IsActive)
                            {
                                <form method="post" action="/Admin/Users/Deactivate/@user.Id" style="display: inline;" onsubmit="return confirm('Bu kullanıcıyı devre dışı bırakmak istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-warning" title="Devre dışı bırak">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/Admin/Users/Activate/@user.Id" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success" title="Etkinleştir">
                                        <i class="fas fa-redo"></i>
                                    </button>
                                </form>
                            }

                            <form method="post" action="/Admin/Users/Delete/@user.Id" style="display: inline;" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="fas fa-inbox me-2"></i>Henüz kullanıcı eklenmemiş
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
