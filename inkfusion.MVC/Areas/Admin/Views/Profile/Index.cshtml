@model User

@{
    ViewData["Title"] = "Profilim";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1 class="page-title">
            <i class="fas fa-user-circle"></i> Profilim
        </h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form method="post" action="@Url.Action("Edit", "Profile", new { area = "Admin" })">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label for="Name" class="form-label">Ad Soyad <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="Name" name="Name"
                               value="@Model.Name" placeholder="Adınız ve soyadınız" required maxlength="255">
                    </div>

                    <div class="mb-3">
                        <label for="Email" class="form-label">E-posta</label>
                        <input type="email" class="form-control" id="Email"
                               value="@Model.Email" disabled>
                        <small class="text-muted">E-posta adresi değiştirilemez</small>
                    </div>

                    <div class="mb-3">
                        <label for="Password" class="form-label">Yeni Şifre (İsteğe Bağlı)</label>
                        <input type="password" class="form-control" id="Password" name="Password"
                               placeholder="Şifre değiştirmek istemiyorsanız boş bırakın" minlength="8" maxlength="100">
                        <small class="text-muted">En az 8 karakter olmalıdır</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Üyelik Tarihi</label>
                        <input type="text" class="form-control"
                               value="@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")" disabled>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Son Güncelleme</label>
                        <input type="text" class="form-control"
                               value="@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")" disabled>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Kaydet
                        </button>
                        <a href="/Admin/Dashboard" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Geri Dön
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-info-circle"></i> Bilgiler
                </h5>
                <hr>
                <p class="mb-2">
                    <strong>Durum:</strong>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">İnaktif</span>
                    }
                </p>
                <p class="mb-0">
                    <strong>Rol:</strong>
                    <span class="badge bg-primary">Yönetici</span>
                </p>
            </div>
        </div>
    </div>
</div>
