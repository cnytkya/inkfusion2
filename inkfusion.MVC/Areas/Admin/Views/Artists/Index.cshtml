@model IEnumerable<Artist>

@{
    ViewData["Title"] = "Sanatçılar Yönetimi";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1 class="page-title">
            <i class="fas fa-users"></i> Sanatçılar Yönetimi
        </h1>
    </div>
    <div class="col-md-4 text-end">
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Sanatçı Ekle
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="table-responsive">
        @if (Model.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Adı</th>
                        <th>Uzmanlık</th>
                        <th>Resim</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var artist in Model)
                    {
                        <tr>
                            <td>
                                <strong>@artist.Name</strong>
                            </td>
                            <td>@artist.Specialty</td>
                            <td>
                                @if (!string.IsNullOrEmpty(artist.ImageUrl))
                                {
                                    <img src="@artist.ImageUrl" alt="@artist.Name" style="height: 40px; width: 40px; object-fit: cover; border-radius: 4px;" />
                                }
                                else
                                {
                                    <span class="text-muted"><i class="fas fa-image"></i> Yok</span>
                                }
                            </td>
                            <td>
                                @if (artist.IsActive)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check"></i> Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-times"></i> İnaktif
                                    </span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", new { id = artist.Id })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Düzenle
                                </a>
                                <form method="post" action="@Url.Action("Delete", new { id = artist.Id })" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bu sanatçıyı silmek istediğinize emin misiniz?');">
                                        <i class="fas fa-trash"></i> Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="card-body">
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i> Henüz hiç sanatçı eklenmemiş.
                    <a href="@Url.Action("Create")" class="alert-link">Şimdi eklemek için tıklayın.</a>
                </div>
            </div>
        }
    </div>
</div>

<style>
.page-title {
    font-size: 2rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 1.5rem;
}

.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    border: none;
}
</style>
